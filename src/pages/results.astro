---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Results — TriCel CxnA | iDEC 2025"
  description="Dry-lab results: AlphaFold3 validation, cellobiose docking, PLIP interaction analysis, and pose convergence. Wet-lab results pending."
>

  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Results</p>
      <h1>Dry-lab results &amp; wet-lab placeholders</h1>
      <p>
        Computational structural analysis is complete. Wet-lab experimental results will
        fill the structured placeholders below as data becomes available.
      </p>
    </div>
  </section>

  <!-- ═══ TOC — pill-bar (mobile/tablet) ═══ -->
  <nav class="toc-pill-bar" aria-label="Jump to result">
    <div class="toc-pill-bar-inner">
      <span class="toc-section-label">Dry lab</span>
      <a href="#drylab-structure">DL-R1</a>
      <a href="#drylab-gh10">DL-R2</a>
      <a href="#drylab-gh1">DL-R3</a>
      <a href="#drylab-docking">DL-R4</a>
      <a href="#drylab-convergence">DL-R5</a>
      <a href="#drylab-plip">DL-R6</a>
      <div class="toc-divider"></div>
      <span class="toc-section-label">Wet lab</span>
      <a href="#wetlab-cloning">WL-R1</a>
      <a href="#wetlab-eppcr">WL-R2</a>
      <a href="#wetlab-selection">WL-R3</a>
      <a href="#wetlab-assays">WL-R4</a>
      <a href="#wetlab-hits">WL-R5</a>
    </div>
  </nav>

  <!-- ═══ TOC — fixed sidebar (desktop ≥1380px) ═══ -->
  <aside class="toc-fixed" aria-label="Results contents">
    <p class="toc-fixed-title">Results</p>
    <nav>
      <p class="toc-group-head">Dry lab</p>
      <a href="#drylab-structure"><span class="toc-id">DL-R1</span><span class="toc-label">Structure quality</span></a>
      <a href="#drylab-gh10"><span class="toc-id">DL-R2</span><span class="toc-label">GH10 docking</span></a>
      <a href="#drylab-gh1"><span class="toc-id">DL-R3</span><span class="toc-label">GH1 docking</span></a>
      <a href="#drylab-docking"><span class="toc-id">DL-R4</span><span class="toc-label">Score caveat</span></a>
      <a href="#drylab-convergence"><span class="toc-id">DL-R5</span><span class="toc-label">Convergence</span></a>
      <a href="#drylab-plip"><span class="toc-id">DL-R6</span><span class="toc-label">PLIP tables</span></a>
      <p class="toc-group-head">Wet lab</p>
      <a href="#wetlab-cloning"><span class="toc-id">WL-R1</span><span class="toc-label">Cloning</span></a>
      <a href="#wetlab-eppcr"><span class="toc-id">WL-R2</span><span class="toc-label">epPCR library</span></a>
      <a href="#wetlab-selection"><span class="toc-id">WL-R3</span><span class="toc-label">Selection</span></a>
      <a href="#wetlab-assays"><span class="toc-id">WL-R4</span><span class="toc-label">Assays</span></a>
      <a href="#wetlab-hits"><span class="toc-id">WL-R5</span><span class="toc-label">Hit validation</span></a>
    </nav>
  </aside>

  <!-- ═══ STATUS SUMMARY ═══ -->
  <section class="section section--alt" aria-labelledby="status-heading">
    <div class="container">
      <h2 id="status-heading" class="sr-only">Results status summary</h2>
      <div class="status-grid">
        <div class="status-card">
          <h3>Dry Lab</h3>
          <div class="status-items">
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> Structure prediction (AlphaFold3)</div>
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> RMSD validation vs 1FHD (0.293 Å)</div>
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> Cellobiose docking — GH10</div>
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> Cellobiose docking — GH1</div>
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> PLIP interaction analysis</div>
            <div class="status-item"><span class="badge badge--confirmed">Confirmed</span> Pose convergence analysis</div>
          </div>
        </div>
        <div class="status-card">
          <h3>Wet Lab</h3>
          <div class="status-items">
            <div class="status-item"><span class="badge badge--progress">In Progress</span> CxnA cloning &amp; expression</div>
            <div class="status-item"><span class="badge badge--progress">In Progress</span> epPCR library generation</div>
            <div class="status-item"><span class="badge badge--progress">In Progress</span> Cellobiose selection (Project A)</div>
            <div class="status-item"><span class="badge badge--progress">In Progress</span> CMC clearing assay (Project B)</div>
            <div class="status-item"><span class="badge badge--pending">Pending</span> MUG/MUC/CMC screening</div>
            <div class="status-item"><span class="badge badge--pending">Pending</span> Hit sequencing &amp; validation</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- ═══ DRY LAB RESULTS ═══════════════════════════════════ -->
  <!-- ══════════════════════════════════════════════════════ -->

  <section class="section" id="drylab" aria-labelledby="drylab-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Computational results</p>
        <h2 id="drylab-heading">Dry Lab — Structural analysis and docking</h2>
      </div>

      <!-- ─── DL-R1: Structure Validation ─── -->
      <div class="result-block" id="drylab-structure">
        <div class="result-header">
          <div class="result-id">DL-R1</div>
          <div>
            <h3>AlphaFold3 structure quality &amp; RMSD validation</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-1, DL-2</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <p>
            AlphaFold3 models were generated for the GH10/Cex domain and the GH1-fold domain
            of CxnA. The GH10/Cex model was validated against the published crystal structure
            1FHD (Notenboom et al., 1998
            <a class="cite" href="#ref-notenboom">[3]</a>) by Cα RMSD alignment in PyMOL.
          </p>

          <div class="key-finding">
            <div class="key-finding-label">Key Result</div>
            <div class="key-finding-value">RMSD = <strong>0.293 Å</strong></div>
            <div class="key-finding-context">
              Cα RMSD over aligned GH10/Cex domain residues vs 1FHD crystal structure.
              This is within the range expected for near-identical structures (&lt;1.0 Å),
              indicating high structural accuracy in the AlphaFold3 model of the
              active-site region.
            </div>
          </div>

          <!-- Figure placeholder -->
          <div class="figure-block">
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">🏗</div>
                <strong>Figure: AlphaFold3 model overlaid on 1FHD crystal structure</strong>
                <p>AlphaFold3 (green) vs 1FHD (grey) structural overlay. Active-site residues GLU127 and GLU233 highlighted. RMSD = 0.293 Å.</p>
                <p class="figure-note">Add PyMOL session screenshot here: <code>figures/drylab/af3_vs_1FHD_overlay.png</code></p>
              </div>
            </div>
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">📈</div>
                <strong>Figure: Per-residue RMSD deviation plot</strong>
                <p>Cα deviation (Å) plotted by residue number. Expected pattern: low RMSD in structured core, higher in loop regions.</p>
                <p class="figure-note">Add matplotlib/pymol figure: <code>figures/drylab/per_residue_rmsd.png</code></p>
              </div>
            </div>
          </div>

          <h4>pLDDT confidence summary</h4>
          <table class="data-table">
            <thead>
              <tr><th>Region</th><th>pLDDT range</th><th>Interpretation</th></tr>
            </thead>
            <tbody>
              <tr><td>GH10 catalytic core (incl. GLU127, GLU233)</td><td class="mono">&gt;90</td><td>Very high confidence — active-site geometry reliable</td></tr>
              <tr><td>GH10 surface loops</td><td class="mono">75–90</td><td>High confidence</td></tr>
              <tr><td>GH1-fold catalytic core (incl. GLU350, GLU404)</td><td class="mono">&gt;85</td><td>High confidence</td></tr>
              <tr><td>Inter-domain linker</td><td class="mono">60–75</td><td>Moderate — expected (intrinsically flexible region)</td></tr>
            </tbody>
          </table>

          <div class="callout">
            <p class="callout-title">Interpretation</p>
            <p>
              An RMSD of 0.293 Å is strong evidence that AlphaFold3 has correctly predicted
              the active-site geometry of the GH10/Cex domain. This validates the use of
              the AlphaFold3 model as the receptor for docking studies (DL-R2). The
              analogous validation for GH1 is limited by the absence of a comparable
              published crystal structure for the CxnA GH1-fold domain; confidence in the
              GH1 predictions is therefore based on pLDDT alone.
            </p>
          </div>
        </div>
      </div>

      <!-- ─── DL-R2: Docking GH10 ─── -->
      <div class="result-block" id="drylab-gh10">
        <div class="result-header">
          <div class="result-id">DL-R2</div>
          <div>
            <h3>Cellobiose docking into GH10/Cex active site (Project B)</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-3, DL-4, DL-5</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <p>
            Autodock Vina docking of cellobiose into the GH10/Cex active site yielded
            consistent, well-converged poses. PLIP analysis of the top-ranked pose
            identified hydrogen-bond contacts with the established catalytic residues
            GLU127 and GLU233, consistent with the expected binding geometry for a GH10
            exoglucanase substrate.
          </p>

          <div class="key-finding">
            <div class="key-finding-label">Top Pose</div>
            <div class="key-finding-value">ΔG = <span class="value-placeholder">[value]</span> kcal/mol</div>
            <div class="key-finding-context">
              Autodock Vina predicted binding free energy for top-ranked cellobiose pose in GH10/Cex.
              Note: absolute values are semi-empirical estimates — see DL-R4 for caveat and xylobiose comparison.
            </div>
          </div>

          <div class="figure-block figure-block--3">
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">🔬</div>
                <strong>Figure: GH10 top docking pose</strong>
                <p>Cellobiose (sticks) in GH10/Cex active site (cartoon). GLU127 and GLU233 shown as sticks.</p>
                <p class="figure-note"><code>figures/drylab/gh10_cellobiose_top_pose.png</code></p>
              </div>
            </div>
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">🗺</div>
                <strong>Figure: PoseView 2D interaction diagram</strong>
                <p>2D ligand-protein interaction map showing H-bond donors/acceptors, hydrophobic contacts.</p>
                <p class="figure-note"><code>figures/drylab/gh10_poseview.png</code></p>
              </div>
            </div>
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">📊</div>
                <strong>Figure: Pose RMSD cluster histogram</strong>
                <p>RMSD distribution across 20 retained poses. Expected: tight clustering (&lt;2 Å) indicating convergence.</p>
                <p class="figure-note"><code>figures/drylab/gh10_pose_cluster.png</code></p>
              </div>
            </div>
          </div>

          <h4>GH10 PLIP interaction summary</h4>
          <table class="data-table">
            <thead>
              <tr><th>Residue</th><th>Interaction type</th><th>Ligand atom</th><th>Distance (Å)</th><th>Role</th></tr>
            </thead>
            <tbody>
              <tr><td class="mono">GLU127</td><td>H-bond (donor)</td><td>O3 cellobiose</td><td class="mono"><span class="value-placeholder">[x.xx]</span></td><td>Catalytic nucleophile</td></tr>
              <tr><td class="mono">GLU233</td><td>H-bond (acceptor)</td><td>O1 cellobiose</td><td class="mono"><span class="value-placeholder">[x.xx]</span></td><td>Acid/base catalyst</td></tr>
              <tr><td class="mono">[additional residues]</td><td>Hydrophobic</td><td>–</td><td class="mono"><span class="value-placeholder">[x.xx]</span></td><td>Binding stabilisation</td></tr>
            </tbody>
          </table>
          <p class="table-note">Full PLIP output file: <code>data/drylab/gh10_cellobiose_plip.txt</code> (to be added to GitHub repo)</p>
        </div>
      </div>

      <!-- ─── DL-R3: Docking GH1 ─── -->
      <div class="result-block" id="drylab-gh1">
        <div class="result-header">
          <div class="result-id">DL-R3</div>
          <div>
            <h3>Cellobiose docking into GH1-fold active site (Project A)</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-3, DL-4, DL-5</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <p>
            Cellobiose was docked into the GH1-fold domain of CxnA (the Project A target).
            The docking results differ significantly from GH10, with important implications
            for the directed evolution strategy.
          </p>

          <div class="key-finding key-finding--warn">
            <div class="key-finding-label">Steric barrier identified</div>
            <div class="key-finding-value">GLN87 &amp; TRP281</div>
            <div class="key-finding-context">
              These two residues form a steric barrier limiting cellobiose access to the
              candidate active-site pocket (GLU350/GLU404). This is a key finding for
              Project A: directed evolution may need to modify or displace these residues
              to permit productive substrate binding. This is a hypothesis, not a proven
              requirement.
            </div>
          </div>

          <div class="figure-block">
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">🔬</div>
                <strong>Figure: GH1 docking poses (all 20 retained)</strong>
                <p>All 20 cellobiose poses shown in GH1 active site. Scattered distribution indicates ambiguous binding.</p>
                <p class="figure-note"><code>figures/drylab/gh1_cellobiose_all_poses.png</code></p>
              </div>
            </div>
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">🚧</div>
                <strong>Figure: GLN87/TRP281 steric barrier</strong>
                <p>Surface representation showing GLN87 and TRP281 blocking the candidate binding pocket relative to GLU350/GLU404.</p>
                <p class="figure-note"><code>figures/drylab/gh1_steric_barrier.png</code></p>
              </div>
            </div>
          </div>

          <h4>GH1 PLIP interaction summary (top pose)</h4>
          <table class="data-table">
            <thead>
              <tr><th>Residue</th><th>Interaction type</th><th>Ligand atom</th><th>Role / Note</th></tr>
            </thead>
            <tbody>
              <tr><td class="mono">GLU350</td><td>H-bond (tentative)</td><td>O cellobiose</td><td>Candidate catalytic nucleophile — weak contact</td></tr>
              <tr><td class="mono">GLU404</td><td>H-bond (tentative)</td><td>O cellobiose</td><td>Candidate acid/base — weak contact</td></tr>
              <tr><td class="mono">GLN87</td><td>Steric clash</td><td>Multiple</td><td><strong>Barrier residue</strong> — partially blocks active-site access</td></tr>
              <tr><td class="mono">TRP281</td><td>Hydrophobic block</td><td>–</td><td><strong>Barrier residue</strong> — hydrophobic bulk limits cellobiose accommodation</td></tr>
            </tbody>
          </table>

          <div class="callout callout--warn">
            <p class="callout-title">Honest interpretation — what this does and does not tell us</p>
            <p>
              The GH1 docking results <strong>do not</strong> demonstrate that the GH1-fold
              domain of CxnA is incapable of binding cellobiose, nor do they prove it is
              capable. They identify structural features that computational methods suggest
              may impede binding. Whether those features are actually barriers to activity —
              and whether directed evolution can overcome them — is an empirical question that
              only wet-lab experiments can answer. The steric barrier finding guides but does
              not constrain the epPCR targeting strategy.
            </p>
          </div>
        </div>
      </div>

      <!-- ─── DL-R4: Docking Caveat / Xylobiose ─── -->
      <div class="result-block" id="drylab-docking">
        <div class="result-header">
          <div class="result-id">DL-R4</div>
          <div>
            <h3>Docking score caveat: xylobiose ΔG comparison</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-3</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <p>
            Xylobiose (a xylose dimer analogous in structure to cellobiose) was docked into
            the GH10/Cex active site as a comparative substrate. This experiment serves as
            an explicit test of docking score interpretability.
          </p>

          <div class="key-finding key-finding--warn">
            <div class="key-finding-label">Caveat demonstrated</div>
            <div class="key-finding-value">Xylobiose score &gt; cellobiose score</div>
            <div class="key-finding-context">
              Autodock Vina predicts xylobiose binds with a more favourable ΔG than cellobiose
              in GH10/Cex — despite cellobiose being the natural substrate. This demonstrates
              that absolute Vina scores overestimate or misrank binding affinity and must not be
              used as direct substitutes for experimental ΔG measurements.
            </div>
          </div>

          <div class="figure-block">
            <div class="figure-panel">
              <div class="placeholder-block">
                <div class="placeholder-icon" aria-hidden="true">📊</div>
                <strong>Figure: Cellobiose vs xylobiose Vina scores in GH10</strong>
                <p>Bar chart comparing top-pose Vina ΔG for cellobiose vs xylobiose. Illustrates score unreliability for substrate identity.</p>
                <p class="figure-note"><code>figures/drylab/cellobiose_vs_xylobiose_scores.png</code></p>
              </div>
            </div>
          </div>

          <div class="callout callout--warn">
            <p class="callout-title">Methodological note — all Vina scores on this site</p>
            <p>
              Throughout this project, Autodock Vina scores are used only for within-receptor,
              within-ligand pose ranking and convergence assessment. They are not used to draw
              conclusions about whether one substrate is preferred over another, nor to predict
              absolute affinity values. All such conclusions require experimental validation.
            </p>
          </div>
        </div>
      </div>

      <!-- ─── DL-R5: Pose Convergence ─── -->
      <div class="result-block" id="drylab-convergence">
        <div class="result-header">
          <div class="result-id">DL-R5</div>
          <div>
            <h3>Pose convergence analysis: GH10 vs GH1</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-5</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <p>
            Pose convergence was assessed by clustering all 20 retained docking poses per
            target by pairwise RMSD (cutoff 2.0 Å). The GH10 and GH1 results show
            strikingly different patterns.
          </p>

          <div class="convergence-compare">
            <div class="convergence-item convergence-item--good">
              <div class="convergence-label">GH10 / Cex</div>
              <div class="convergence-status"><span class="badge badge--confirmed">Tight convergence</span></div>
              <p>
                The majority of the 20 poses cluster within 2 Å RMSD of the top-ranked pose.
                This indicates that Autodock Vina consistently identifies the same binding
                geometry, supporting high confidence in the predicted GH10–cellobiose binding
                mode and the PLIP analysis based on it.
              </p>
              <div class="placeholder-block mt-4" style="padding:var(--sp-4)">
                <div class="placeholder-icon" aria-hidden="true">📊</div>
                <strong>Figure: GH10 pose RMSD histogram</strong>
                <p class="figure-note"><code>figures/drylab/gh10_pose_convergence.png</code></p>
              </div>
            </div>

            <div class="convergence-item convergence-item--warn">
              <div class="convergence-label">GH1-fold</div>
              <div class="convergence-status"><span class="badge badge--progress">Scattered — investigation ongoing</span></div>
              <p>
                GH1 poses are distributed across multiple clusters with no dominant pose.
                This indicates that Autodock Vina does not identify a clear, preferred binding
                site for cellobiose in the GH1-fold domain, consistent with the absence of
                a pre-formed binding pocket in the wild-type structure.
              </p>
              <p class="mt-4">
                <strong>This result is not over-interpreted.</strong> Pose scatter does not
                prove that GH1 cannot bind cellobiose — it indicates computational ambiguity.
                It is flagged as an open question and a motivation for the directed evolution
                approach: if structural changes in the binding pocket are needed, directed
                evolution may identify them.
              </p>
              <div class="placeholder-block mt-4" style="padding:var(--sp-4)">
                <div class="placeholder-icon" aria-hidden="true">📊</div>
                <strong>Figure: GH1 pose RMSD histogram</strong>
                <p class="figure-note"><code>figures/drylab/gh1_pose_convergence.png</code></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ─── DL-R6: PLIP summary ─── -->
      <div class="result-block" id="drylab-plip">
        <div class="result-header">
          <div class="result-id">DL-R6</div>
          <div>
            <h3>Full PLIP interaction tables</h3>
            <div class="result-meta">
              <span class="badge badge--confirmed">Confirmed</span>
              <span class="result-method">Methods: <a href={`${b}/methods#drylab`}>DL-4</a></span>
            </div>
          </div>
        </div>
        <div class="result-body">
          <h4>GH10 — Cellobiose interactions (top pose)</h4>
          <table class="data-table">
            <thead>
              <tr><th>Interaction</th><th>Protein residue</th><th>Ligand atom</th><th>Distance (Å)</th><th>Angle (°)</th></tr>
            </thead>
            <tbody>
              <tr><td>H-bond</td><td class="mono">GLU127</td><td>O3</td><td class="mono value-placeholder">[x.xx]</td><td class="mono value-placeholder">[xxx]</td></tr>
              <tr><td>H-bond</td><td class="mono">GLU233</td><td>O1</td><td class="mono value-placeholder">[x.xx]</td><td class="mono value-placeholder">[xxx]</td></tr>
              <tr><td>Hydrophobic</td><td class="mono">[residue]</td><td>–</td><td class="mono value-placeholder">[x.xx]</td><td>–</td></tr>
            </tbody>
          </table>
          <p class="table-note">Full PLIP report: <code>data/drylab/gh10_cellobiose_plip_full.txt</code></p>

          <h4 class="mt-6">GH1 — Cellobiose interactions (top pose)</h4>
          <table class="data-table">
            <thead>
              <tr><th>Interaction</th><th>Protein residue</th><th>Ligand atom</th><th>Distance (Å)</th><th>Note</th></tr>
            </thead>
            <tbody>
              <tr><td>H-bond (weak)</td><td class="mono">GLU350</td><td>O</td><td class="mono value-placeholder">[x.xx]</td><td>Candidate nucleophile</td></tr>
              <tr><td>H-bond (weak)</td><td class="mono">GLU404</td><td>O</td><td class="mono value-placeholder">[x.xx]</td><td>Candidate acid/base</td></tr>
              <tr><td>Steric clash</td><td class="mono">GLN87</td><td>Multiple</td><td class="mono value-placeholder">[x.xx]</td><td>Barrier residue</td></tr>
