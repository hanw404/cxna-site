---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const allEntries = await getCollection('labnotes');

// Sort chronologically
allEntries.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

// Group by week (ISO week key: YYYY-Wnn)
function weekKey(date: Date) {
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const day = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - day);
  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
  const week = Math.ceil((((d.getTime() - yearStart.getTime()) / 86400000) + 1) / 7);
  return `${d.getUTCFullYear()}-W${String(week).padStart(2, '0')}`;
}

function weekLabel(date: Date) {
  // "Week of 15 June 2026"
  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const day = d.getUTCDay() || 7;
  const monday = new Date(d);
  monday.setUTCDate(d.getUTCDate() - (day - 1));
  return monday.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
}

type Entry = typeof allEntries[0];
const grouped = new Map<string, { label: string; entries: Entry[] }>();
for (const entry of allEntries) {
  const key = weekKey(entry.data.date);
  if (!grouped.has(key)) {
    grouped.set(key, { label: weekLabel(entry.data.date), entries: [] });
  }
  grouped.get(key)!.entries.push(entry);
}
const weeks = Array.from(grouped.values());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
}

function typeLabel(t: string) {
  return t === 'wet-lab' ? 'Wet lab' : 'Dry lab';
}
function typeClass(t: string) {
  return t === 'wet-lab' ? 'badge--wet' : 'badge--dry';
}
function projectLabel(p: string) {
  if (p === 'A') return 'Project A';
  if (p === 'B') return 'Project B';
  return 'Both';
}
function statusClass(s: string) {
  if (s === 'confirmed') return 'badge--confirmed';
  if (s === 'in-progress') return 'badge--progress';
  return 'badge--pending';
}
function statusLabel(s: string) {
  if (s === 'confirmed') return 'Confirmed';
  if (s === 'in-progress') return 'In progress';
  return 'Pending';
}
---

<BaseLayout
  title="Lab Notebook — TriCel CxnA Directed Evolution"
  description="Dated wet-lab and dry-lab notebook entries from the CxnA directed evolution project, June–July 2026."
>

  <div class="page-hero">
    <div class="container">
      <p class="page-eyebrow">Research record</p>
      <h1>Lab Notebook</h1>
      <p class="page-lead">
        Wet-lab and dry-lab entries in chronological order — protocols, observations,
        computational analyses, and results as they happened. Negative and inconclusive
        results are preserved honestly.
      </p>
      <div class="notebook-filters" role="group" aria-label="Filter by lab type">
        <button class="filter-btn filter-btn--active" data-filter="all">All entries</button>
        <button class="filter-btn filter-btn--wet" data-filter="wet-lab">Wet lab</button>
        <button class="filter-btn filter-btn--dry" data-filter="dry-lab">Dry lab</button>
        <span class="filter-count" aria-live="polite"></span>
      </div>
      <div class="notebook-legend">
        <span class="badge badge--confirmed">Confirmed</span>
        <span class="badge badge--progress">In progress</span>
        <span class="badge badge--pending">Pending</span>
      </div>
    </div>
  </div>

  <main id="main" class="container notebook-index">

    {weeks.map((week, wi) => (
      <section class="week-group" id={`week-${wi + 1}`}>
        <h2 class="week-heading">
          <span class="week-label">Week of {week.label}</span>
        </h2>
        <div class="entry-list">
          {week.entries.map(entry => (
            <a href={`${b}/notebook/${entry.slug}`} class="entry-card" data-type={entry.data.type}>
              <div class="entry-card-date">{formatDate(entry.data.date)}</div>
              <div class="entry-card-body">
                <h3 class="entry-card-title">{entry.data.title}</h3>
                <div class="entry-card-meta">
                  <span class={`badge badge--sm ${typeClass(entry.data.type)}`}>{typeLabel(entry.data.type)}</span>
                  <span class="entry-card-project">{projectLabel(entry.data.project)}</span>
                  <span class={`badge badge--sm ${statusClass(entry.data.status)}`}>{statusLabel(entry.data.status)}</span>
                </div>
              </div>
              <span class="entry-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>
    ))}

  </main>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.entry-card');
    const weeks = document.querySelectorAll<HTMLElement>('.week-group');
    const countEl = document.querySelector<HTMLElement>('.filter-count');

    function applyFilter(filter: string) {
      let visible = 0;
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.type === filter;
        card.hidden = !match;
        if (match) visible++;
      });
      // Hide week sections that have no visible cards
      weeks.forEach(week => {
        const anyVisible = Array.from(week.querySelectorAll<HTMLElement>('.entry-card'))
          .some(c => !c.hidden);
        week.hidden = !anyVisible;
      });
      if (countEl) {
        countEl.textContent = filter === 'all' ? '' : `${visible} ${visible === 1 ? 'entry' : 'entries'}`;
      }
      buttons.forEach(btn => {
        btn.classList.toggle('filter-btn--active', btn.dataset.filter === filter);
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
    });
  </script>

</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--c-primary-dim) 0%, var(--c-surface) 100%);
    border-bottom: 1px solid var(--c-border);
    padding: var(--sp-10) 0 var(--sp-8);
  }
  .page-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary);
    margin: 0 0 var(--sp-3);
  }
  .page-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--c-secondary);
    margin: 0 0 var(--sp-4);
  }
  .page-lead {
    max-width: 60ch;
    color: var(--c-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 var(--sp-5);
  }
  .notebook-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
    margin-bottom: var(--sp-4);
  }
  .filter-btn {
    padding: 0.35em 1em;
    border-radius: 999px;
    border: 1.5px solid var(--c-border);
    background: var(--c-surface);
    color: var(--c-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-btn:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
  }
  .filter-btn--active {
    background: var(--c-primary);
    border-color: var(--c-primary);
    color: #fff;
  }
  .filter-btn--active:hover {
    color: #fff;
  }
  .filter-btn--wet.filter-btn--active {
    background: var(--c-primary);
    border-color: var(--c-primary);
  }
  .filter-btn--dry.filter-btn--active {
    background: var(--c-secondary);
    border-color: var(--c-secondary);
  }
  .filter-count {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    margin-left: var(--sp-1);
  }
  .notebook-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
  }

  .notebook-index {
    padding-top: var(--sp-10);
    padding-bottom: var(--sp-16);
  }

  .week-group + .week-group { margin-top: var(--sp-12); }

  .week-heading {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin: 0 0 var(--sp-4);
    padding-bottom: var(--sp-2);
    border-bottom: 2px solid var(--c-border);
  }

  .entry-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .entry-card {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: center;
    gap: var(--sp-4);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-4) var(--sp-5);
    color: var(--c-text);
    text-decoration: none;
    transition: all 0.18s ease;
  }
  .entry-card:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-md);
    transform: translateX(3px);
    text-decoration: none;
  }

  .entry-card-date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--c-primary);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .entry-card-title {
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--c-secondary);
    margin: 0 0 var(--sp-2);
    line-height: 1.3;
  }

  .entry-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
  }

  .entry-card-project {
    font-size: 0.75rem;
    color: var(--c-text-muted);
  }

  .entry-card-arrow {
    color: var(--c-text-muted);
    font-size: 1.1rem;
    transition: transform 0.18s ease, color 0.18s ease;
  }
  .entry-card:hover .entry-card-arrow {
    transform: translateX(4px);
    color: var(--c-primary);
  }

  /* badge size variant */
  .badge--sm {
    font-size: 0.68rem;
    padding: 0.15em 0.55em;
  }
  /* type badges */
  .badge--wet {
    background: color-mix(in srgb, var(--c-primary) 15%, transparent);
    color: var(--c-primary);
    border-color: color-mix(in srgb, var(--c-primary) 30%, transparent);
  }
  .badge--dry {
    background: color-mix(in srgb, var(--c-secondary) 12%, transparent);
    color: var(--c-secondary);
    border-color: color-mix(in srgb, var(--c-secondary) 25%, transparent);
  }

  @media (max-width: 600px) {
    .entry-card {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }
    .entry-card-date {
      grid-column: 1;
      grid-row: 1;
    }
    .entry-card-arrow {
      grid-column: 2;
      grid-row: 1 / 3;
    }
    .entry-card-body {
      grid-column: 1;
      grid-row: 2;
    }
  }
</style>
