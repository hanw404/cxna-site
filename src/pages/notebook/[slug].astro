---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const b = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const entries = await getCollection('labnotes');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Sort all entries to find prev/next
const allEntries = await getCollection('labnotes');
allEntries.sort((a, b) => {
  const dateDiff = a.data.date.getTime() - b.data.date.getTime();
  if (dateDiff !== 0) return dateDiff;
  // same date: dry before wet
  return a.data.type.localeCompare(b.data.type);
});
const idx = allEntries.findIndex(e => e.slug === entry.slug);
const prev = idx > 0 ? allEntries[idx - 1] : null;
const next = idx < allEntries.length - 1 ? allEntries[idx + 1] : null;

const { title, date, project, type, status } = entry.data;

function typeLabel(t: string) { return t === 'wet-lab' ? 'Wet lab' : 'Dry lab'; }
function typeClass(t: string) { return t === 'wet-lab' ? 'badge--wet' : 'badge--dry'; }
function projectLabel(p: string) {
  if (p === 'A') return 'Project A';
  if (p === 'B') return 'Project B';
  return 'Both projects';
}
function statusClass(s: string) {
  if (s === 'confirmed') return 'badge--confirmed';
  if (s === 'in-progress') return 'badge--progress';
  return 'badge--pending';
}
function statusLabel(s: string) {
  if (s === 'confirmed') return 'Confirmed';
  if (s === 'in-progress') return 'In progress';
  return 'Pending';
}
const formattedDate = date.toLocaleDateString('en-GB', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC',
});
---

<BaseLayout title={`${title} — Lab Notebook | TriCel`} description={`Lab notebook entry: ${title}, ${formattedDate}.`}>

  <div class="entry-hero">
    <div class="container">
      <a href={`${b}/notebook`} class="back-link">← All entries</a>
      <p class="entry-date">{formattedDate}</p>
      <h1>{title}</h1>
      <div class="entry-badges">
        <span class={`badge ${typeClass(type)}`}>{typeLabel(type)}</span>
        <span class="badge badge--neutral">{projectLabel(project)}</span>
        <span class={`badge ${statusClass(status)}`}>{statusLabel(status)}</span>
      </div>
    </div>
  </div>

  <main id="main" class="container entry-body">
    <article class="prose">
      <Content />
    </article>

    <nav class="entry-nav" aria-label="Adjacent notebook entries">
      <div class="entry-nav-prev">
        {prev && (
          <a href={`${b}/notebook/${prev.slug}`} class="entry-nav-link entry-nav-link--prev">
            <span class="entry-nav-dir">← Previous entry</span>
            <span class="entry-nav-title">{prev.data.title}</span>
            <span class="entry-nav-meta">
              {prev.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', timeZone: 'UTC' })}
              &nbsp;·&nbsp;{prev.data.type === 'wet-lab' ? 'Wet lab' : 'Dry lab'}
            </span>
          </a>
        )}
      </div>
      <div class="entry-nav-next">
        {next && (
          <a href={`${b}/notebook/${next.slug}`} class="entry-nav-link entry-nav-link--next">
            <span class="entry-nav-dir">Next entry →</span>
            <span class="entry-nav-title">{next.data.title}</span>
            <span class="entry-nav-meta">
              {next.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', timeZone: 'UTC' })}
              &nbsp;·&nbsp;{next.data.type === 'wet-lab' ? 'Wet lab' : 'Dry lab'}
            </span>
          </a>
        )}
      </div>
    </nav>
  </main>

</BaseLayout>

<style>
  .entry-hero {
    background: linear-gradient(135deg, var(--c-primary-dim) 0%, var(--c-surface) 100%);
    border-bottom: 1px solid var(--c-border);
    padding: var(--sp-8) 0 var(--sp-6);
  }
  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--c-primary);
    text-decoration: none;
    margin-bottom: var(--sp-4);
    opacity: 0.85;
    transition: opacity 0.15s;
  }
  .back-link:hover { opacity: 1; }

  .entry-date {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    margin: 0 0 var(--sp-2);
  }
  .entry-hero h1 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    color: var(--c-secondary);
    margin: 0 0 var(--sp-4);
    line-height: 1.25;
  }
  .entry-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  /* badge type variants (same as notebook index) */
  .badge--wet {
    background: color-mix(in srgb, var(--c-primary) 15%, transparent);
    color: var(--c-primary);
    border-color: color-mix(in srgb, var(--c-primary) 30%, transparent);
  }
  .badge--dry {
    background: color-mix(in srgb, var(--c-secondary) 12%, transparent);
    color: var(--c-secondary);
    border-color: color-mix(in srgb, var(--c-secondary) 25%, transparent);
  }
  .badge--neutral {
    background: var(--c-surface-alt, var(--c-surface));
    color: var(--c-text-muted);
    border-color: var(--c-border);
  }

  .entry-body {
    padding-top: var(--sp-10);
    padding-bottom: var(--sp-16);
  }

  /* ─── Prose ─── */
  .prose {
    max-width: 70ch;
  }
  .prose h2 {
    font-size: 1.25rem;
    color: var(--c-secondary);
    margin: var(--sp-8) 0 var(--sp-3);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--c-border);
  }
  .prose h2:first-child { margin-top: 0; border-top: none; padding-top: 0; }
  .prose h3 {
    font-size: 1.05rem;
    color: var(--c-secondary);
    margin: var(--sp-5) 0 var(--sp-2);
  }
  .prose h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: var(--sp-4) 0 var(--sp-2);
  }
  .prose p { margin: 0 0 var(--sp-4); line-height: 1.75; }
  .prose ul, .prose ol { margin: 0 0 var(--sp-4); padding-left: var(--sp-6); }
  .prose li { margin-bottom: var(--sp-2); line-height: 1.6; }
  .prose strong { color: var(--c-secondary); }
  .prose em { font-style: italic; }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--c-surface-alt, color-mix(in srgb, var(--c-border) 40%, transparent));
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }
  .prose blockquote {
    border-left: 3px solid var(--c-primary);
    margin: var(--sp-4) 0;
    padding: var(--sp-3) var(--sp-5);
    background: color-mix(in srgb, var(--c-primary) 6%, transparent);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--c-text-muted);
    font-style: italic;
  }
  .prose blockquote p { margin: 0; }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    margin: var(--sp-4) 0;
    overflow-x: auto;
    display: block;
  }
  .prose th {
    background: color-mix(in srgb, var(--c-primary) 8%, transparent);
    color: var(--c-secondary);
    font-weight: 600;
    text-align: left;
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 2px solid var(--c-border);
    white-space: nowrap;
  }
  .prose td {
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--c-border);
    vertical-align: top;
  }
  .prose tr:last-child td { border-bottom: none; }
  .prose tr:nth-child(even) { background: color-mix(in srgb, var(--c-border) 20%, transparent); }

  /* ─── Prev / Next navigation ─── */
  .entry-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
    margin-top: var(--sp-12);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--c-border);
  }
  .entry-nav-next { text-align: right; }

  .entry-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-4);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    color: var(--c-text);
    text-decoration: none;
    transition: all 0.18s ease;
  }
  .entry-nav-link:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .entry-nav-dir {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .entry-nav-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--c-secondary);
    line-height: 1.3;
  }
  .entry-nav-meta {
    font-size: 0.75rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 540px) {
    .entry-nav { grid-template-columns: 1fr; }
    .entry-nav-next { text-align: left; }
  }
</style>
