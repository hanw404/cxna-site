---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="Methods — TriCel CxnA | iDEC 2025"
  description="Full methods for the CxnA directed evolution project: AlphaFold3, Autodock Vina, PLIP analysis, cloning, error-prone PCR, selection, and enzyme assays."
>

