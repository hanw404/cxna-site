---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="TriCel — CxnA Directed Evolution | iDEC 2025"
  description="Engineering a trifunctional cellulose-degrading enzyme via directed evolution. An iDEC 2025 research project combining AlphaFold3 structural analysis with wet-lab molecular biology."
>

  <!-- ═══ HERO ═══ -->
  <section class="hero" aria-labelledby="hero-heading">
    <!-- Full-hero Three.js molecular canvas (absolute background layer) -->
    <div class="hero-3d" id="hero-canvas-container" aria-hidden="true"></div>
    <!-- Ambient particle field — populated and animated by GSAP -->
    <svg class="hero-particles" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"></svg>
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">iDEC 2025 &mdash; Directed Evolution</p>
        <h1 id="hero-heading">
          <span class="hero-line">One enzyme.</span>
          <span class="hero-line">Three activities.</span>
          <span class="hero-line"><span class="hero-accent">Cellulose to glucose.</span></span>
        </h1>
        <p class="hero-lead">
          We are engineering a single protein capable of breaking down crystalline cellulose
          all the way to usable glucose &mdash; by evolving a new catalytic activity into
          CxnA, a naturally bifunctional cellulase from <em>Cellulomonas fimi</em>.
        </p>
        <div class="hero-actions">
          <a href={`${b}/overview`} class="btn btn-primary">Project Overview</a>
          <a href={`${b}/results`} class="btn btn-secondary">View Results</a>
        </div>
        <a
          href="https://idec.io"
          target="_blank"
          rel="noopener"
          class="idec-badge mt-6"
          aria-label="iDEC — International Directed Evolution Competition (opens in new tab)"
        >
          <span class="idec-dot" aria-hidden="true"></span>
          Affiliated with iDEC
          <span class="idec-badge-note">International Directed Evolution Competition</span>
        </a>
      </div>

      <!-- right column empty — molecule fills the right half from behind -->
    </div>
  </section>

  <!-- ═══ PROJECT A / B OVERVIEW ═══ -->
  <section class="section section--alt" aria-labelledby="projects-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Two parallel tracks</p>
        <h2 id="projects-heading">What this project is doing</h2>
        <p>
          CxnA already does two things. We want to give it a third — and make those first two better.
        </p>
      </div>

      <div class="grid-2">
        <div class="card card--accent project-card">
          <div class="project-label">Project A</div>
          <h3>Trifunctional evolution</h3>
          <p class="mt-4">
            Using directed evolution to introduce <strong>beta-glucosidase activity</strong>
            into the GH1 domain of CxnA. If successful, the resulting enzyme would convert
            cellulose all the way to glucose in a single protein, without requiring a
            separate beta-glucosidase.
          </p>
          <p class="mt-4">
            No direct precedent exists in the literature for evolving a GH10 scaffold toward
            GH1-type activity. This project tests that gap directly.
          </p>
          <div class="project-tags mt-6">
            <span class="badge badge--progress">In Progress</span>
            <span class="tag">epPCR</span>
            <span class="tag">MUG selection</span>
            <span class="tag">GH1 docking</span>
          </div>
        </div>

        <div class="card card--accent project-card">
          <div class="project-label">Project B</div>
          <h3>Activity enhancement</h3>
          <p class="mt-4">
            Using directed evolution to improve CxnA's <strong>existing exoglucanase and
            endoglucanase activities</strong> — making it a more efficient cellulose-degrading
            enzyme overall, regardless of whether Project A succeeds.
          </p>
          <p class="mt-4">
            Guided by the AlphaFold3 structural analysis and PLIP interaction maps to target
            residues most likely to influence substrate binding and catalytic efficiency.
          </p>
          <div class="project-tags mt-6">
            <span class="badge badge--progress">In Progress</span>
            <span class="tag">epPCR</span>
            <span class="tag">CMC assay</span>
            <span class="tag">GH10 docking</span>
          </div>
        </div>
      </div>

      <!-- Why it matters -->
      <div class="callout mt-8">
        <p class="callout-title">Why this matters</p>
        <p>
          Cellulose is the most abundant organic material on Earth. Converting it to glucose
          efficiently — without expensive multi-enzyme cocktails — could make biofuel production
          and biomass recycling significantly cheaper and more practical. This project also tests
          how far AI-assisted structural prediction can responsibly guide directed evolution, and
          where it cannot substitute for real experimental data.
        </p>
      </div>

      <!-- CxnA domain schematic (annotated, dark-card figure) -->
      <figure class="enzyme-figure mt-8" aria-label="CxnA three-domain enzyme architecture">
        <figcaption class="enzyme-fig-caption">CxnA enzyme &mdash; domain architecture &amp; substrate flow</figcaption>
        <svg viewBox="0 0 500 320" xmlns="http://www.w3.org/2000/svg" class="enzyme-svg">
          <defs>
            <linearGradient id="chainGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#2d9c6e"/>
              <stop offset="60%" style="stop-color:#1a6648"/>
              <stop offset="100%" style="stop-color:#c9862a"/>
            </linearGradient>
            <filter id="glow">
              <feGaussianBlur stdDeviation="2" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <!-- Substrate labels top -->
          <text x="90" y="28" text-anchor="middle" font-size="11" fill="#7ec9a6" font-family="system-ui,sans-serif" font-weight="600">CRYSTALLINE</text>
          <text x="90" y="42" text-anchor="middle" font-size="11" fill="#7ec9a6" font-family="system-ui,sans-serif" font-weight="600">CELLULOSE</text>
          <text x="250" y="28" text-anchor="middle" font-size="11" fill="#7ec9a6" font-family="system-ui,sans-serif" font-weight="600">AMORPHOUS</text>
          <text x="250" y="42" text-anchor="middle" font-size="11" fill="#7ec9a6" font-family="system-ui,sans-serif" font-weight="600">CELLULOSE &amp; CELLOBIOSE</text>
          <text x="415" y="28" text-anchor="middle" font-size="11" fill="#f0a830" font-family="system-ui,sans-serif" font-weight="600">GLUCOSE</text>
          <text x="415" y="42" text-anchor="middle" font-size="11" fill="#f0a830" font-family="system-ui,sans-serif" font-weight="600">(USABLE FUEL)</text>

          <!-- Arrow connectors between domains -->
          <path d="M150,160 L178,160" stroke="#4aa87a" stroke-width="2" marker-end="url(#arrowGreen)" fill="none"/>
          <path class="evolving-arrow" d="M315,160 L343,160" stroke="#c9862a" stroke-width="2.5" stroke-dasharray="5,3" marker-end="url(#arrowAmber)" fill="none"/>
          <text x="329" y="150" text-anchor="middle" font-size="9.5" fill="#c9862a" font-family="system-ui,sans-serif" font-style="italic">evolving →</text>

          <defs>
            <marker id="arrowGreen" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="#4aa87a"/>
            </marker>
            <marker id="arrowAmber" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="#c9862a"/>
            </marker>
          </defs>

          <!-- GH10 / Exoglucanase domain -->
          <rect x="20" y="120" width="130" height="80" rx="12" fill="#1a6648" filter="url(#glow)"/>
          <text x="85" y="152" text-anchor="middle" font-size="13" fill="white" font-family="system-ui,sans-serif" font-weight="700">GH10 / Cex</text>
          <text x="85" y="169" text-anchor="middle" font-size="10.5" fill="#a8d5bc" font-family="system-ui,sans-serif">Exoglucanase</text>
          <text x="85" y="185" text-anchor="middle" font-size="9.5" fill="#7ec9a6" font-family="system-ui,sans-serif">attacks chain ends</text>
          <text x="85" y="212" text-anchor="middle" font-size="9" fill="#5aaa85" font-family="system-ui,sans-serif">EXISTING ACTIVITY</text>

          <!-- GH10 / Endoglucanase domain -->
          <rect x="178" y="120" width="137" height="80" rx="12" fill="#1a6648" filter="url(#glow)"/>
          <text x="247" y="152" text-anchor="middle" font-size="13" fill="white" font-family="system-ui,sans-serif" font-weight="700">GH10 / CenA</text>
          <text x="247" y="169" text-anchor="middle" font-size="10.5" fill="#a8d5bc" font-family="system-ui,sans-serif">Endoglucanase</text>
          <text x="247" y="185" text-anchor="middle" font-size="9.5" fill="#7ec9a6" font-family="system-ui,sans-serif">internal chain cleavage</text>
          <text x="247" y="212" text-anchor="middle" font-size="9" fill="#5aaa85" font-family="system-ui,sans-serif">EXISTING ACTIVITY</text>

          <!-- GH1 / Beta-glucosidase domain (the evolving target) -->
          <rect class="gh1-border" x="343" y="112" width="140" height="96" rx="12" fill="#8a5a12" stroke="#c9862a" stroke-width="2.5" stroke-dasharray="6,3"/>
          <text x="413" y="147" text-anchor="middle" font-size="13" fill="white" font-family="system-ui,sans-serif" font-weight="700">GH1 domain</text>
          <text x="413" y="164" text-anchor="middle" font-size="10.5" fill="#f0c070" font-family="system-ui,sans-serif">&beta;-glucosidase</text>
          <text x="413" y="181" text-anchor="middle" font-size="9.5" fill="#f0c070" font-family="system-ui,sans-serif">cellobiose &rarr; glucose</text>
          <text x="413" y="200" text-anchor="middle" font-size="9" fill="#c9862a" font-family="system-ui,sans-serif">TARGET (Project A)</text>

          <!-- Linker region -->
          <rect x="148" y="150" width="32" height="20" rx="4" fill="#0d4a32"/>
          <text x="164" y="163" text-anchor="middle" font-size="8" fill="#4aa87a" font-family="system-ui,sans-serif">linker</text>

          <!-- Protein chain line underneath -->
          <path d="M20,230 Q250,255 480,230" stroke="url(#chainGrad)" stroke-width="3" fill="none" opacity="0.4"/>
          <text x="250" y="250" text-anchor="middle" font-size="10" fill="#7ec9a6" font-family="system-ui,sans-serif" font-style="italic">single polypeptide chain (CxnA)</text>

          <!-- Legend -->
          <rect x="20" y="270" width="12" height="12" rx="2" fill="#1a6648"/>
          <text x="37" y="281" font-size="9.5" fill="#a8d5bc" font-family="system-ui,sans-serif">Existing activity (CxnA WT)</text>
          <rect x="200" y="270" width="12" height="12" rx="2" fill="none" stroke="#c9862a" stroke-width="2" stroke-dasharray="4,2"/>
          <text x="217" y="281" font-size="9.5" fill="#f0c070" font-family="system-ui,sans-serif">Evolved target &mdash; Project A</text>
        </svg>
      </figure>
    </div>
  </section>

  <!-- ═══ APPROACH OVERVIEW ═══ -->
  <section class="section" aria-labelledby="approach-heading">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">How we're doing it</p>
        <h2 id="approach-heading">Dry lab + wet lab, in parallel</h2>
      </div>

      <div class="grid-3">
        <div class="approach-card">
          <div class="approach-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          </div>
          <h3>Structural prediction</h3>
          <p>AlphaFold3 models of the GH10 and GH1 domains, validated against the 1FHD crystal structure (RMSD 0.293 Å).</p>
          <a href={`${b}/results#drylab-structure`} class="approach-link">See validation results →</a>
        </div>
        <div class="approach-card">
          <div class="approach-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5z"/><path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5z"/></svg>
          </div>
          <h3>Molecular docking</h3>
          <p>Autodock Vina docking of cellobiose into both active sites, with PLIP interaction analysis of key catalytic residues.</p>
          <a href={`${b}/results#drylab-docking`} class="approach-link">See docking results →</a>
        </div>
        <div class="approach-card">
          <div class="approach-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          </div>
          <h3>Directed evolution</h3>
          <p>Error-prone PCR mutagenesis libraries screened by growth on selective media and fluorogenic enzyme assays.</p>
          <a href={`${b}/methods#wetlab`} class="approach-link">See methods →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ NAV CARDS ═══ -->
  <section class="section section--alt" aria-labelledby="nav-heading">
    <div class="container">
      <h2 id="nav-heading" class="sr-only">Site sections</h2>
      <div class="nav-cards">
        <a href={`${b}/science`} class="nav-card">
          <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </span>
          <h3>The Science</h3>
          <p>Cellulose degradation biology, CxnA's origin, directed evolution, and key literature.</p>
        </a>
        <a href={`${b}/methods`} class="nav-card">
          <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.31L5.72 18.5A2 2 0 0 0 7.59 21h8.82a2 2 0 0 0 1.87-2.5L14 9.31V2"/><line x1="8.5" y1="2" x2="15.5" y2="2"/><line x1="7" y1="16" x2="17" y2="16"/></svg>
          </span>
          <h3>Methods</h3>
          <p>Full dry-lab and wet-lab protocols — AlphaFold3, Autodock Vina, cloning, epPCR, assays.</p>
        </a>
        <a href={`${b}/results`} class="nav-card">
          <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
          </span>
          <h3>Results</h3>
          <p>Dry-lab structural and docking results, plus structured placeholders for incoming wet-lab data.</p>
        </a>
        <a href={`${b}/overview`} class="nav-card">
          <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
          </span>
          <h3>Full Overview</h3>
          <p>The complete project context, both tracks explained side by side, and iDEC affiliation details.</p>
        </a>
        <a href={`${b}/notebook`} class="nav-card">
          <span class="nav-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
          </span>
          <h3>Lab Notebook</h3>
          <p>Dated wet-lab and dry-lab entries — protocols, observations, and computational analyses as they happened.</p>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ───────────────────────────────────────────────────── */
  .hero {
    background: linear-gradient(145deg, #152e24 0%, #1a4a35 50%, #1f5a42 100%);
    padding-block: 4rem 3rem;
    overflow: hidden;
    position: relative;
  }
  .hero-particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-10);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-3d    { display: none; }  /* hide canvas on mobile — text-only hero */
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7ec9a6;
    margin-bottom: var(--sp-4);
  }
  h1 { color: #ffffff; line-height: 1.1; font-size: clamp(2rem, 4.5vw, 3rem); }
  .hero-accent {
    background: linear-gradient(90deg, #7ec9a6 0%, #3dd68c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-lead {
    color: rgba(232,244,238,0.82);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-top: var(--sp-5);
    max-width: 52ch;
  }
  .hero-actions {
    display: flex;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-5);
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.92rem;
    transition: all 0.18s;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--c-primary);
    color: #fff;
    border: 2px solid var(--c-primary);
  }
  .btn-primary:hover { background: var(--c-primary-hover); border-color: var(--c-primary-hover); text-decoration: none; }
  .btn-secondary {
    background: transparent;
    color: #e8f4ee;
    border: 2px solid rgba(232,244,238,0.35);
  }
  .btn-secondary:hover { border-color: #7ec9a6; color: #7ec9a6; text-decoration: none; }

  .idec-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(232,244,238,0.7);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-md);
    padding: var(--sp-2) var(--sp-3);
    text-decoration: none;
    transition: all 0.18s;
  }
  .idec-badge:hover { border-color: #7ec9a6; color: #7ec9a6; text-decoration: none; }
  .idec-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #7ec9a6;
    flex-shrink: 0;
  }
  .idec-badge-note {
    font-weight: 400;
    font-size: 0.76em;
    opacity: 0.75;
  }

  /* ─── Three.js full-hero canvas (absolute background) ──────── */
  .hero-3d {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
  }
  .hero-3d canvas { display: block; }

  /* ─── Enzyme schematic figure (project section) ─────────────── */
  .enzyme-figure {
    background: linear-gradient(135deg, #152e24 0%, #1a4a35 100%);
    border-radius: var(--radius-lg);
    padding: var(--sp-5) var(--sp-5) var(--sp-4);
    overflow: hidden;
    margin: 0;
  }
  .enzyme-fig-caption {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7ec9a6;
    margin-bottom: var(--sp-3);
  }
  .enzyme-svg { width: 100%; display: block; }

  /* ─── Project cards ─────────────────────────────────────────── */
  .project-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: var(--c-primary-light);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.5em;
    display: inline-block;
    margin-bottom: var(--sp-3);
  }
  .project-card h3 { color: var(--c-secondary); }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--c-text-muted);
    background: var(--c-surface-2);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.55em;
  }

  /* ─── Approach cards ────────────────────────────────────────── */
  .approach-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
  }
  .approach-icon {
    width: 32px;
    height: 32px;
    color: var(--c-primary);
    margin-bottom: var(--sp-3);
  }
  .approach-icon svg { width: 100%; height: 100%; }
  .approach-card h3 { color: var(--c-secondary); margin-bottom: var(--sp-2); }
  .approach-card p { font-size: 0.92rem; color: var(--c-text-muted); }
  .approach-link {
    display: inline-block;
    margin-top: var(--sp-4);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--c-primary);
  }

  /* ─── Nav cards ─────────────────────────────────────────────── */
  .nav-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-4);
  }
  .nav-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    text-decoration: none;
    color: var(--c-text);
    transition: all 0.2s;
    display: block;
  }
  .nav-card:hover {
    border-color: var(--c-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .nav-card-icon {
    display: block;
    width: 28px;
    height: 28px;
    color: var(--c-primary);
    margin-bottom: var(--sp-3);
  }
  .nav-card-icon svg { width: 100%; height: 100%; }
  .nav-card h3 { color: var(--c-secondary); font-size: 1.05rem; margin-bottom: var(--sp-2); }
  .nav-card p { font-size: 0.88rem; color: var(--c-text-muted); max-width: none; }

  /* ─── Hero elements — GSAP sets opacity/transform; layout only ── */
  .hero-line    { display: block; opacity: 0; text-shadow: 0 2px 16px rgba(0,0,0,0.7); }
  .hero-eyebrow { opacity: 0; }
  .hero-lead    { text-shadow: 0 1px 10px rgba(0,0,0,0.6); }
  .hero-actions { position: relative; }

  /* ─── SVG diagram animations (enzyme schematic — project section) */
  @keyframes flow-arrow {
    to { stroke-dashoffset: -8; }
  }
  @keyframes march-border {
    to { stroke-dashoffset: -9; }
  }
  .evolving-arrow { animation: flow-arrow 1s linear infinite; }
  .gh1-border     { animation: march-border 4s linear infinite; }

  /* ─── prefers-reduced-motion ──────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-line, .hero-eyebrow      { opacity: 1; }
    .hero-3d                       { display: none; }
    .hero-inner                    { grid-template-columns: 1fr; }
    .evolving-arrow, .gh1-border   { animation: none; }
  }

  /* ─── Utility ───────────────────────────────────────────────── */
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {

    // ── Ambient particle field ─────────────────────────────────────
    const particleSvg = document.querySelector('.hero-particles');
    if (particleSvg) {
      const GREENS = ['#7ec9a6', '#4aa87a', '#3dd68c', '#a8d5bc', '#2d9c6e'];
      const AMBERS = ['#c9862a', '#f0a830', '#d4973a'];
      const rand   = gsap.utils.random;

      for (let i = 0; i < 38; i++) {
        const isProduct = i < 9;
        const palette   = isProduct ? AMBERS : GREENS;
        const color     = palette[Math.floor(Math.random() * palette.length)];
        const r         = rand(isProduct ? 1.5 : 1.5, isProduct ? 3.5 : 5);

        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('r',    String(r));
        circle.setAttribute('cx',   String(rand(0, 1000)));
        circle.setAttribute('cy',   String(rand(0, 600)));
        circle.setAttribute('fill', color);
        particleSvg.appendChild(circle);

        gsap.set(circle, { opacity: rand(0.1, 0.42) });
        gsap.to(circle, {
          x: rand(-55, 55), y: rand(-38, 38), opacity: rand(0.05, 0.38),
          duration: rand(5, 14), repeat: -1, yoyo: true,
          ease: 'sine.inOut', delay: rand(0, 7),
        });
      }
    }

    // y-offset initial state (opacity is set via CSS)
    gsap.set('.hero-line',    { y: 14 });
    gsap.set('.hero-eyebrow', { y: 8 });

    // ── Hero entrance timeline ─────────────────────────────────────
    const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
    tl
      .to('.hero-line',      { opacity: 1, y: 0, duration: 0.55, stagger: 0.12 })
      .to('.hero-eyebrow',   { opacity: 1, y: 0, duration: 0.4 },              '-=0.2')
      .to('.hero-3d',        { opacity: 1, duration: 0.9, ease: 'power1.in' }, '-=0.1')
      .to('.hero-particles', { opacity: 1, duration: 2.2, ease: 'power1.in' }, '-=0.5');
  }
</script>

<script>
  import * as THREE from 'three';

  const el = document.getElementById('hero-canvas-container') as HTMLElement | null;

  if (
    !el ||
    window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
    window.innerWidth <= 860
  ) {
    // nothing
  } else {
    initMolecule(el);
  }

  function initMolecule(container: HTMLElement): void {
    const W = container.clientWidth  || 800;
    const H = container.clientHeight || 460;

    // ── Scene ──────────────────────────────────────────────────────
    const scene  = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, W / H, 0.1, 100);
    camera.position.z = 8;

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(W, H);
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    container.appendChild(renderer.domElement);

    // ── Lighting ───────────────────────────────────────────────────
    scene.add(new THREE.AmbientLight(0xffffff, 0.18));

    // Sky-blue key light (illuminates GH10 from upper-left)
    const gLight = new THREE.PointLight(0x7dd3fc, 3.5, 28);
    gLight.position.set(-2, 5, 8);
    scene.add(gLight);

    // Amber fill light (illuminates GH1 from lower-right)
    const aLight = new THREE.PointLight(0xfbbf24, 3.0, 24);
    aLight.position.set(11, -3, 7);
    scene.add(aLight);

    // White top fill
    const fLight = new THREE.PointLight(0xffffff, 1.0, 32);
    fLight.position.set(4, 9, 10);
    scene.add(fLight);

    // ── Mouse-following lamp — the interactive "circle of influence" ──
    // Projects cursor world-space position on z=0, illuminates nearby spheres
    const mouseLamp = new THREE.PointLight(0xffffff, 0, 10, 1.5);
    scene.add(mouseLamp);

    // ── Shared geometry + dummy ────────────────────────────────────
    const geo   = new THREE.SphereGeometry(1, 9, 7);
    const dummy = new THREE.Object3D();

    // ── Sphere cluster — surface-biased random packing ─────────────
    type Sp = { x: number; y: number; z: number; r: number };

    function cluster(cx: number, cy: number, cz: number, radius: number, n: number): Sp[] {
      const out: Sp[] = [];
      while (out.length < n) {
        const theta = Math.random() * Math.PI * 2;
        const phi   = Math.acos(2 * Math.random() - 1);
        const r     = radius * (0.38 + 0.62 * Math.cbrt(Math.random())); // bias toward surface
        out.push({
          x: cx + r * Math.sin(phi) * Math.cos(theta),
          y: cy + r * Math.sin(phi) * Math.sin(theta),
          z: cz + r * Math.cos(phi) * 0.78,  // slightly flattened in z
          r: 0.13 + Math.random() * 0.22,    // larger spheres for hero-scale visibility
        });
      }
      return out;
    }

    // Centres: GH10 (sky-blue, left) — GH1 (amber, right — the evolving target)
    const GH10_C = [-2.5, 0.5, 0] as const;
    const GH1_C  = [ 2.5, -0.5, 0] as const;

    const gh10All = cluster(GH10_C[0], GH10_C[1], GH10_C[2], 2.4, 180);
    const gh1All  = cluster(GH1_C[0],  GH1_C[1],  GH1_C[2],  2.2, 160);

    // Linker — quadratic bezier arc
    const linker: Sp[] = Array.from({ length: 32 }, (_, i) => {
      const t = i / 31, mt = 1 - t;
      return {
        x: mt*mt * GH10_C[0] + 2*mt*t * 0   + t*t * GH1_C[0],
        y: mt*mt * GH10_C[1] + 2*mt*t * 1.0 + t*t * GH1_C[1],
        z: mt*mt * GH10_C[2] + 2*mt*t * 0.4 + t*t * GH1_C[2],
        r: 0.08 + Math.random() * 0.06,
      };
    });

    // Active-site spheres: rightmost GH10 / leftmost GH1 (the evolving pocket)
    const topNIdx = (arr: Sp[], sign: 1 | -1, n: number): Set<number> =>
      new Set(arr.map((s, i) => ({ i, v: s.x * sign }))
        .sort((a, b) => b.v - a.v).slice(0, n).map(e => e.i));

    const gh10AIdx = topNIdx(gh10All, 1, 9);
    const gh1AIdx  = topNIdx(gh1All, -1, 9);

    const gh10Reg = gh10All.filter((_, i) => !gh10AIdx.has(i));
    const gh10Act = gh10All.filter((_, i) =>  gh10AIdx.has(i));
    const gh1Reg  = gh1All.filter( (_, i) => !gh1AIdx.has(i));
    const gh1Act  = gh1All.filter( (_, i) =>  gh1AIdx.has(i));

    // ── Materials — sky-blue / amber: high contrast on dark green ──
    const mGH10  = new THREE.MeshPhongMaterial({ color: 0x7dd3fc, emissive: 0x0c3a52, shininess: 80 });
    const mGH1   = new THREE.MeshPhongMaterial({ color: 0xfbbf24, emissive: 0x7c3800, shininess: 80 });
    const mLink  = new THREE.MeshPhongMaterial({
      color: 0xd0f0ff, emissive: 0x224466, shininess: 25, transparent: true, opacity: 0.42,
    });
    const mGH10A = new THREE.MeshPhongMaterial({
      color: 0xbae6fd, emissive: 0x7dd3fc, emissiveIntensity: 0.7, shininess: 140,
    });
    const mGH1A  = new THREE.MeshPhongMaterial({
      color: 0xfde68a, emissive: 0xfbbf24, emissiveIntensity: 0.9, shininess: 140,
    });

    // ── Build InstancedMeshes (one draw call per material) ─────────
    function buildMesh(spheres: Sp[], mat: THREE.MeshPhongMaterial): THREE.InstancedMesh {
      const m = new THREE.InstancedMesh(geo, mat, spheres.length);
      m.frustumCulled = false;
      spheres.forEach((s, i) => {
        dummy.position.set(s.x, s.y, s.z);
        dummy.scale.setScalar(s.r);
        dummy.updateMatrix();
        m.setMatrixAt(i, dummy.matrix);
      });
      m.instanceMatrix.needsUpdate = true;
      return m;
    }

    const meshGH10  = buildMesh(gh10Reg, mGH10);
    const meshGH1   = buildMesh(gh1Reg,  mGH1);
    const meshLink  = buildMesh(linker,  mLink);
    const meshGH10A = buildMesh(gh10Act, mGH10A);
    const meshGH1A  = buildMesh(gh1Act,  mGH1A);

    const group = new THREE.Group();
    group.add(meshGH10, meshGH1, meshLink, meshGH10A, meshGH1A);
    // Shift molecule into right ~60% of the hero; text sits in the left half
    group.position.x = 3.5;
    scene.add(group);

    // ── Mouse tracking (NDC) ───────────────────────────────────────
    // Listen on the hero section so .hero-inner (z-index:1) doesn't
    // block events — events on siblings bubble up to the parent section.
    const mouse = new THREE.Vector2(9999, 9999);
    const heroSection = container.closest('section') ?? container;
    heroSection.addEventListener('mousemove', e => {
      const rect = container.getBoundingClientRect();
      mouse.set(
        ((e.clientX - rect.left) / rect.width)  *  2 - 1,
        ((e.clientY - rect.top)  / rect.height) * -2 + 1,
      );
    });
    heroSection.addEventListener('mouseleave', () => mouse.set(9999, 9999));

    // Pre-allocated — avoid per-frame GC pressure
    const _ray        = new THREE.Vector3();
    const _mouseWorld = new THREE.Vector3();

    // ── Animation loop ─────────────────────────────────────────────
    const clock = new THREE.Clock();
    let raf = 0;

    function tick(): void {
      raf = requestAnimationFrame(tick);
      const t = clock.getElapsedTime();

      // Slow auto-rotation + gentle wobble
      group.rotation.y = t * 0.065;
      group.rotation.x = Math.sin(t * 0.035) * 0.07;

      // ── Mouse lamp: project NDC cursor → world space (z = 0 plane) ──
      // Creates a smooth sphere of influence: nearest spheres light up,
      // periphery fades naturally via the PointLight's distance falloff
      if (mouse.x < 100) {
        _ray.set(mouse.x, mouse.y, 0.5).unproject(camera).sub(camera.position).normalize();
        const tHit = -camera.position.z / _ray.z;
        _mouseWorld.copy(camera.position).addScaledVector(_ray, tHit);
        mouseLamp.position.copy(_mouseWorld);
        mouseLamp.intensity = 8;
      } else {
        mouseLamp.intensity = 0;
      }

      // ── Active-site emissive pulse ─────────────────────────────
      const p1 = 0.5 + 0.5 * Math.sin(t * 1.3);
      const p2 = 0.5 + 0.5 * Math.sin(t * 1.9 + 0.7); // GH1 faster — it's the evolving target
      mGH10A.emissiveIntensity = 0.35 + p1 * 0.85;
      mGH1A.emissiveIntensity  = 0.5  + p2 * 1.1;

      // GH1 active-site scale-pulse (marks the evolving pocket)
      const sc = 1 + p2 * 0.08;
      gh1Act.forEach((s, i) => {
        dummy.position.set(s.x, s.y, s.z);
        dummy.scale.setScalar(s.r * sc);
        dummy.updateMatrix();
        meshGH1A.setMatrixAt(i, dummy.matrix);
      });
      meshGH1A.instanceMatrix.needsUpdate = true;

      renderer.render(scene, camera);
    }
    tick();

    // ── Resize observer ────────────────────────────────────────────
    const ro = new ResizeObserver(() => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      if (!w || !h) return;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
    ro.observe(container);

    // ── Cleanup on Astro view transitions ─────────────────────────
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      renderer.dispose();
      ro.disconnect();
    }, { once: true });
  }
</script>
